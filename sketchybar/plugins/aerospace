#!/bin/sh

NAME=${NAME:-"space.1"}

BACKGROUND="0xff1e1e2e"; # Base
FOREGROUND="0xffcdd6f4"; # Text
TRANSPARENT="0x00000000";

AEROSPACE="/run/current-system/sw/bin/aerospace"
SPACE=$(echo "$NAME" | sed 's/space\.//')

if [ -n "$FOCUSED_WORKSPACE" ]; then
  FOCUSED="$FOCUSED_WORKSPACE"
else
  FOCUSED=$("$AEROSPACE" list-workspaces --focused 2>/dev/null || echo "1")
fi
bg=$TRANSPARENT
fg=$FOREGROUND
if [ "$SPACE" = "$FOCUSED" ]; then
  bg=$FOREGROUND
  fg=$BACKGROUND
fi
sketchybar --set "$NAME" background.color=$bg label.color=$fg
