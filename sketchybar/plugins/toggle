#!/usr/bin/env swift

import AppKit
import CoreGraphics
import Foundation

// MARK: - Tuning

let triggerZone: CGFloat = 2
let releaseZone: CGFloat = 32

// sketchybar 実行コマンド
let sketchybarExecutable = "/usr/bin/env"
let sketchybarBaseArguments = ["sketchybar", "--bar"]

// MARK: - State

var isHidden = false
var eventTap: CFMachPort?

// MARK: - Helpers

func openAccessibilitySettings() {
    guard let url = URL(string: "x-apple.systempreferences:com.apple.preference.security?Privacy_Accessibility") else {
        return
    }
    NSWorkspace.shared.open(url)
}

func screenContaining(_ point: CGPoint) -> NSScreen? {
    NSScreen.screens.first { screen in
        screen.frame.contains(point)
    }
}

func setSketchyBar(hidden: Bool) {
    guard hidden != isHidden else { return }
    isHidden = hidden

    let process = Process()
    process.executableURL = URL(fileURLWithPath: sketchybarExecutable)
    process.arguments = sketchybarBaseArguments + ["hidden=\(hidden ? "on" : "off")"]

    Task {
        if !hidden {
            try await Task.sleep(for: .milliseconds(300))
        }
        do {
            try process.run()
        } catch {
            fputs("failed to run sketchybar: \(error)\n", stderr)
        }
    }
}

func handlePointer(at location: CGPoint) {
    if !isHidden && location.y <= triggerZone {
        setSketchyBar(hidden: true)
    } else if isHidden && location.y >= releaseZone {
        setSketchyBar(hidden: false)
    }
}

func restoreAndExit(_ code: Int32) -> Never {
    setSketchyBar(hidden: false)
    exit(code)
}

// MARK: - Event Tap Callback

let callback: CGEventTapCallBack = { _, type, event, _ in
    switch type {
    case .tapDisabledByTimeout, .tapDisabledByUserInput:
        if let tap = eventTap {
            CGEvent.tapEnable(tap: tap, enable: true)
        }
        return Unmanaged.passUnretained(event)

    case .mouseMoved, .leftMouseDragged, .rightMouseDragged, .otherMouseDragged:
        handlePointer(at: event.location)
        return Unmanaged.passUnretained(event)

    default:
        return Unmanaged.passUnretained(event)
    }
}

// MARK: - Main

let mask: CGEventMask =
    (1 << CGEventType.mouseMoved.rawValue) |
    (1 << CGEventType.leftMouseDragged.rawValue) |
    (1 << CGEventType.rightMouseDragged.rawValue) |
    (1 << CGEventType.otherMouseDragged.rawValue)

guard let tap = CGEvent.tapCreate(
    tap: .cgSessionEventTap,
    place: .headInsertEventTap,
    options: .defaultTap,
    eventsOfInterest: mask,
    callback: callback,
    userInfo: nil
) else {
    openAccessibilitySettings()
    exit(1)
}

eventTap = tap

let runLoopSource = CFMachPortCreateRunLoopSource(kCFAllocatorDefault, tap, 0)
CFRunLoopAddSource(CFRunLoopGetMain(), runLoopSource, .commonModes)
CGEvent.tapEnable(tap: tap, enable: true)

signal(SIGINT) { _ in
    restoreAndExit(0)
}

signal(SIGTERM) { _ in
    restoreAndExit(0)
}

RunLoop.main.run()
