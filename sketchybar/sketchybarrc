#!/bin/sh

PLUGIN_DIR="$CONFIG_DIR/plugins"

BACKGROUND="0xff1e1e2e"; # Base
BACKGROUND_TRANSPARENT="0xcc1e1e2e";
CURRENT_LINE="0xff313244"; # Surface0
FOREGROUND="0xffcdd6f4"; # Text
COMMENT="0xff6c7086"; # Overlay0
WARNING="0xfff38ba8"; # Red
TRANSPARENT="0x00000000";

BRACKET_HEIGHT=20

sketchybar --add event aerospace_workspace_change
bar=(
  display=main
  height=28
  color="$BACKGROUND_TRANSPARENT"
  shadow=on
  position=top
  sticky=on
  padding_left=8
  padding_right=8
  margin=8
  corner_radius=12
  blur_radius=30
  notch_width=200
  y_offset=4
)
sketchybar --bar "${bar[@]}"

default=(
  icon.font="Hack Nerd Font:Bold:14.0"
  icon.color="$FOREGROUND"
  icon.padding_left=6
  icon.padding_right=4
  label.font="Hack Nerd Font:Bold:12.0"
  label.color="$FOREGROUND"
  label.padding_left=4
  label.padding_right=6
  background.color="$TRANSPARENT"
  background.corner_radius=8
  background.height=28
  background.padding_left=2
  background.padding_right=2
)
sketchybar --default "${default[@]}"

workspace() {
  sid=$1
  sketchybar --add item space.$sid left \
             --set space.$sid \
                   icon.drawing=off \
                   padding_left=4 padding_right=4 \
                   label="$sid" label.padding_left=10 label.padding_right=12 \
                   background.height=$BRACKET_HEIGHT \
                   click_script="aerospace workspace $sid" \
                   script="$PLUGIN_DIR/aerospace" \
                   update_freq=60 \
                   --subscribe space.$sid aerospace_workspace_change
}

plugin() {
  name=$1
  event=${2:-}
  position=${3:-right}

  sketchybar --add item "$name" "$position" \
             --set "$name" \
                   update_freq=60 \
                   script="$PLUGIN_DIR/$name"

  [ -z "$event" ] || sketchybar --subscribe "$name" "$event"
}

bracket() {
  sketchybar --add bracket "$1_bracket" "$2" \
             --set "$1_bracket" background.color="$CURRENT_LINE" background.height=$BRACKET_HEIGHT
}

separator() {
  sketchybar --add item "separator_$1" "${3:-right}" \
             --set "separator_$1" \
                   label=│ \
                   label.color="$COMMENT" \
                   padding_left=0 \
                   padding_right=8 \
                   icon.drawing=off \
                   background.drawing=off
}

sketchybar --add item apple_logo left \
           --set apple_logo \
                 icon="" \
                 icon.font="SF Pro:Bold:16.0" \
                 icon.padding_left=8 icon.padding_right=8 \
                 label.drawing=off \
                 background.color="$CURRENT_LINE" \
                 background.height=$BRACKET_HEIGHT \
                 padding_right=8 \
                 click_script="sketchybar --reload"

workspace 1
workspace 2
workspace 3
workspace 4
workspace 5
workspace 6
plugin front_app front_app_switched left
plugin date system_woke
separator date
plugin ime
separator ime
plugin battery
separator battery
plugin volume volume_change

bracket spaces '/space\..*/'
bracket ime ime
bracket network volume
bracket power battery
bracket date date

AEROSPACE="/run/current-system/sw/bin/aerospace"
FOCUSED=$("$AEROSPACE" list-workspaces --focused 2>/dev/null || echo "1")
sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE="$FOCUSED"

ps aux | grep '[s]ketchybar/plugins/toggle' | awk '{ print $2 }' | xargs kill
~/.config/sketchybar/plugins/toggle &

sketchybar --update
