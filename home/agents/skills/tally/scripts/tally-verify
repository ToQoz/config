#!/usr/bin/env python3
"""
tally-verify — walk a tally workspace and re-verify every signed clause
from the filesystem. Treats contract.yaml as the source of truth.

Usage:
    tally-verify <workspace-dir>

    Example:
    tally-verify ./.agents/share/tally/user-export-csv

Exit codes:
    0  all signed clauses verify; per-requirement coverage OK
    1  one or more violations (printed to stdout)
    2  invocation or parse error (printed to stderr)

Verification per signed clause:
    - observations/<record-id>.md exists
    - frontmatter has required fields (id, requirement_ids, command, cwd,
      env, timestamp, outcome, exit_code)
    - frontmatter outcome matches clause oracle_result
    - clause requirement_id is in observation requirement_ids
    - evidence body is non-empty

Per-Requirement-ID coverage:
    - at least one effective (signed, not superseded) clause exists
    - at least one effective signed clause cites an observation with
      `independent: true` frontmatter flag (see SKILL.md § Invariants)
    - no unsuperseded failing or unsigned clause remains for this R-###

Oracle-method enforcement:
    Each signed clause's observation `produced_by` must appear in the
    clause's oracle's `allowed_producers` (parsed from oracle-map.md).
    A substitution is allowed only when the clause carries
    `substituted_check: true`, a non-empty `substitution_reason`, and
    `oracle-map.md` contains an authorizing `## Reopened` note.
"""

from __future__ import annotations

import pathlib
import re
import sys

try:
    import yaml
except ImportError:
    sys.stderr.write(
        "tally-verify requires PyYAML.\n"
        "Install with one of:\n"
        "  nix-shell -p python3Packages.pyyaml --run 'tally-verify ...'\n"
        "  pip install pyyaml\n"
    )
    sys.exit(2)


REQUIRED_OBS_FIELDS = (
    "id",
    "requirement_ids",
    "command",
    "cwd",
    "env",
    "timestamp",
    "outcome",
    "exit_code",
    "produced_by",
)

KNOWN_PRODUCERS = frozenset(
    {
        "tally-record",
        "step-through-code",
        "tui-acceptance-checks",
        "webapp-acceptance-checks",
    }
)


def parse_frontmatter(md_path: pathlib.Path) -> tuple[dict | None, str]:
    text = md_path.read_text()
    if not text.startswith("---\n"):
        return None, text
    end = text.find("\n---\n", 4)
    if end == -1:
        return None, text
    frontmatter = yaml.safe_load(text[4:end])
    body = text[end + 5 :]
    return frontmatter, body


def parse_producers_cell(raw: str) -> list[str]:
    s = raw.strip()
    if s.startswith("[") and s.endswith("]"):
        s = s[1:-1]
    if not s:
        return []
    return [p.strip().strip("`") for p in s.split(",") if p.strip()]


def parse_oracle_map(path: pathlib.Path) -> dict[str, dict]:
    """Parse oracle-map.md's structured table. Returns R-### -> {observation_method, allowed_producers}."""
    if not path.exists():
        return {}
    oracles: dict[str, dict] = {}
    for line in path.read_text().splitlines():
        stripped = line.strip()
        if not stripped.startswith("|"):
            continue
        parts = [p.strip() for p in line.split("|")]
        if parts and parts[0] == "":
            parts = parts[1:]
        if parts and parts[-1] == "":
            parts = parts[:-1]
        if len(parts) < 6:
            continue
        req_id = parts[0].strip("`")
        if not re.fullmatch(r"R-\d+", req_id):
            continue
        method = parts[4].strip("`")
        producers = parse_producers_cell(parts[5])
        oracles[req_id] = {
            "observation_method": method,
            "allowed_producers": producers,
        }
    return oracles


def verify(workspace: pathlib.Path) -> int:
    contract_path = workspace / "contract.yaml"
    if not contract_path.exists():
        sys.stderr.write(f"error: {contract_path} not found\n")
        return 2

    try:
        contract = yaml.safe_load(contract_path.read_text()) or {}
    except yaml.YAMLError as e:
        sys.stderr.write(f"error: failed to parse {contract_path}: {e}\n")
        return 2

    clauses = contract.get("clauses") or []
    observations_dir = workspace / "observations"

    oracle_map_path = workspace / "oracle-map.md"
    oracles = parse_oracle_map(oracle_map_path)
    oracle_map_text = oracle_map_path.read_text() if oracle_map_path.exists() else ""
    has_reopen_note = "## Reopened" in oracle_map_text

    # Build supersedes map (old_clause_id -> superseding_clause_id)
    superseded_by: dict[str, str] = {}
    for c in clauses:
        sup = c.get("supersedes")
        if sup:
            superseded_by[sup] = c["clause_id"]

    violations: list[tuple[str, str]] = []

    # Per-clause verification (for signed clauses only)
    for c in clauses:
        cid = c.get("clause_id", "<no-id>")
        if c.get("signature_status") != "signed":
            continue

        record_id = c.get("observation_record_id")
        if not record_id:
            violations.append((cid, "no observation_record_id"))
            continue

        record_path = observations_dir / f"{record_id}.md"
        if not record_path.exists():
            violations.append((cid, f"observation file not found: {record_path}"))
            continue

        fm, body = parse_frontmatter(record_path)
        if not fm:
            violations.append((cid, "observation missing or malformed frontmatter"))
            continue

        missing = [f for f in REQUIRED_OBS_FIELDS if f not in fm]
        if missing:
            violations.append(
                (cid, f"observation frontmatter missing: {', '.join(missing)}")
            )
            continue

        env = fm.get("env")
        if not isinstance(env, dict) or "os" not in env:
            violations.append(
                (
                    cid,
                    "observation env must be a mapping with at least `os`; "
                    f"got {type(env).__name__}",
                )
            )
            continue

        if not body.strip():
            violations.append((cid, "observation evidence body is empty"))
            continue

        produced_by = fm.get("produced_by")
        if produced_by not in KNOWN_PRODUCERS:
            violations.append(
                (
                    cid,
                    f"observation produced_by={produced_by!r} is not in the known "
                    f"producer whitelist ({', '.join(sorted(KNOWN_PRODUCERS))}); "
                    "hand-written records are not valid evidence",
                )
            )
            continue

        oracle_result = c.get("oracle_result")
        outcome = fm.get("outcome")
        if oracle_result == "pass" and outcome != "pass":
            violations.append(
                (cid, f"clause oracle_result=pass but observation outcome={outcome}")
            )
            continue
        if oracle_result == "fail" and outcome == "pass":
            violations.append(
                (cid, "clause oracle_result=fail but observation outcome=pass")
            )
            continue

        req_id = c.get("requirement_id")
        obs_req_ids = fm.get("requirement_ids") or []
        if req_id not in obs_req_ids:
            violations.append(
                (
                    cid,
                    f"clause Requirement ID {req_id} not in observation "
                    f"requirement_ids {obs_req_ids}",
                )
            )
            continue

        oracle = oracles.get(req_id)
        if oracle is None:
            violations.append(
                (cid, f"no oracle row found in oracle-map.md for {req_id}")
            )
            continue
        allowed = set(oracle.get("allowed_producers") or [])
        if not allowed:
            violations.append(
                (
                    cid,
                    f"oracle {req_id} has no allowed_producers declared; "
                    "cannot verify any observation against it",
                )
            )
            continue
        if produced_by not in allowed:
            if c.get("substituted_check") is True:
                reason = (c.get("substitution_reason") or "").strip()
                if not reason:
                    violations.append(
                        (
                            cid,
                            "substituted_check=true requires a non-empty "
                            "substitution_reason",
                        )
                    )
                    continue
                if not has_reopen_note:
                    violations.append(
                        (
                            cid,
                            "substituted_check=true requires an authorizing "
                            "'## Reopened' note in oracle-map.md — no such note "
                            "was found",
                        )
                    )
                    continue
                # Authorized substitution: allow through.
            else:
                violations.append(
                    (
                        cid,
                        f"observation produced_by={produced_by!r} not in "
                        f"oracle {req_id} allowed_producers={sorted(allowed)}; "
                        "set substituted_check=true with substitution_reason "
                        "and an oracle-map.md '## Reopened' authorization note "
                        "if the substitution is user-approved",
                    )
                )
                continue

    # Per-Requirement-ID coverage
    by_req: dict[str, list[dict]] = {}
    for c in clauses:
        by_req.setdefault(c.get("requirement_id"), []).append(c)

    # Gather declared R-### ids from requirement.md if present (so we can flag
    # requirements with zero clauses too)
    declared_req_ids: set[str] = set()
    req_md = workspace / "requirement.md"
    if req_md.exists():
        for line in req_md.read_text().splitlines():
            for m in re.finditer(r"\bR-\d+\b", line):
                declared_req_ids.add(m.group())

    all_req_ids = declared_req_ids | set(k for k in by_req.keys() if k)
    for rid in sorted(all_req_ids):
        cs = by_req.get(rid, [])
        if not cs:
            violations.append((rid, "no clauses for this Requirement ID"))
            continue

        effective_signed = [
            c
            for c in cs
            if c.get("signature_status") == "signed"
            and c.get("clause_id") not in superseded_by
        ]
        if not effective_signed:
            violations.append(
                (rid, "no effective signed clause (signed and not superseded)")
            )
            continue

        pending = [
            c
            for c in cs
            if (
                c.get("signature_status") != "signed"
                or c.get("oracle_result") == "fail"
            )
            and c.get("clause_id") not in superseded_by
        ]
        if pending:
            pending_ids = ", ".join(c.get("clause_id", "<no-id>") for c in pending)
            violations.append(
                (
                    rid,
                    f"unsuperseded unsigned/failing clauses remain: {pending_ids}",
                )
            )
            continue

        any_independent = False
        for c in effective_signed:
            rec_id = c.get("observation_record_id")
            if not rec_id:
                continue
            rec_path = observations_dir / f"{rec_id}.md"
            if not rec_path.exists():
                continue
            fm, _ = parse_frontmatter(rec_path)
            if fm and fm.get("independent") is True:
                any_independent = True
                break
        if not any_independent:
            violations.append(
                (
                    rid,
                    "no effective signed clause cites an independent observation "
                    "(observation frontmatter needs `independent: true`)",
                )
            )

    if not violations:
        print(f"ok: all clauses verified for {workspace}")
        return 0

    for target, reason in violations:
        print(f"FAIL [{target}]: {reason}")
    print(f"\n{len(violations)} violation(s) in {workspace}")
    return 1


def main() -> int:
    if len(sys.argv) != 2 or sys.argv[1] in ("-h", "--help"):
        sys.stderr.write(__doc__)
        return 2
    workspace = pathlib.Path(sys.argv[1]).resolve()
    if not workspace.is_dir():
        sys.stderr.write(f"error: {workspace} is not a directory\n")
        return 2
    return verify(workspace)


if __name__ == "__main__":
    sys.exit(main())
