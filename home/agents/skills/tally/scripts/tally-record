#!/usr/bin/env python3
"""
tally-record — run a command, capture its outcome, and write the result
as an observation record under a tally workspace.

The point of this wrapper is to make observation provenance structural:
a valid record exists only because a real subprocess ran here, right now,
and the wrapper stamped `produced_by: tally-record` with captured
outputs. Hand-written observation files do not pass verification.

Usage:
    tally-record \\
        --slug <slug> \\
        --requirement-ids R-001[,R-002,...] \\
        [--id <record-id>] \\
        [--independent] \\
        [--expect pass|fail] \\
        [--supersedes <old-record-id>] \\
        [--workspace-root <path>] \\
        [--cwd <dir>] \\
        [--notes <free text>] \\
        -- <command> [args...]

Frontmatter populated automatically:
    id              <record-id> (matches filename stem)
    requirement_ids [R-###, ...]
    command         full argv as a single quoted string
    cwd             actual working directory at run time
    env             mapping with {os, [tool_versions], [relevant_env_vars]}
                    os is populated from platform.platform() automatically;
                    tool_versions (from --tool name=version) and
                    relevant_env_vars (from --capture-env NAME) are optional
    timestamp       ISO-8601 UTC (%Y-%m-%dT%H:%M:%SZ)
    outcome         pass | fail | error (derived from exit_code + --expect)
    exit_code       the subprocess exit code
    produced_by     tally-record
    independent     true|false (optional, only when --independent is passed)
    supersedes      <old-id> (optional, only when --supersedes is passed)
    notes           <text> (optional, only when --notes is passed)

Body: stdout + stderr in fenced blocks so the real output is retained.

Exit codes:
    0  observation recorded successfully (regardless of subprocess outcome)
    2  invocation error (bad args, workspace not found, write failed)
"""

from __future__ import annotations

import argparse
import os
import pathlib
import platform
import re
import subprocess
import sys
import time

try:
    import yaml
except ImportError:
    sys.stderr.write(
        "tally-record requires PyYAML.\n"
        "Install with one of:\n"
        "  nix-shell -p python3Packages.pyyaml --run 'tally-record ...'\n"
        "  pip install pyyaml\n"
    )
    sys.exit(2)


DEFAULT_WORKSPACE_ROOT = pathlib.Path(".agents/share/tally")


def iso_timestamp() -> str:
    return time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())


def default_record_id(command: list[str]) -> str:
    ts = iso_timestamp().replace(":", "-")
    if command:
        head = os.path.basename(command[0])
        head = re.sub(r"[^A-Za-z0-9._-]+", "-", head)[:30].strip("-") or "cmd"
    else:
        head = "cmd"
    return f"{ts}-{head}"


def determine_outcome(exit_code: int, expect: str) -> str:
    if exit_code < 0:
        return "error"  # killed by signal
    if expect == "pass":
        return "pass" if exit_code == 0 else "fail"
    if expect == "fail":
        return "pass" if exit_code != 0 else "fail"
    return "error"


def parse_requirement_ids(raw: str) -> list[str]:
    ids = [s.strip() for s in raw.split(",") if s.strip()]
    for rid in ids:
        if not re.fullmatch(r"R-\d+", rid):
            sys.stderr.write(
                f"tally-record: requirement id '{rid}' does not match R-### format\n"
            )
            sys.exit(2)
    return ids


def format_command(command: list[str]) -> str:
    import shlex

    return shlex.join(command)


def write_record(
    record_path: pathlib.Path,
    frontmatter: dict,
    stdout: str,
    stderr: str,
) -> None:
    record_path.parent.mkdir(parents=True, exist_ok=True)
    fm_text = yaml.safe_dump(
        frontmatter,
        sort_keys=False,
        allow_unicode=True,
        default_flow_style=False,
    ).rstrip()
    body_parts = ["---", fm_text, "---", ""]
    if stdout:
        body_parts.extend(["## stdout", "", "```", stdout.rstrip("\n"), "```", ""])
    if stderr:
        body_parts.extend(["## stderr", "", "```", stderr.rstrip("\n"), "```", ""])
    if not stdout and not stderr:
        body_parts.extend(["(no stdout or stderr captured)", ""])
    record_path.write_text("\n".join(body_parts))


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Run a command and record its outcome as a tally observation.",
        add_help=True,
    )
    parser.add_argument("--slug", required=True)
    parser.add_argument("--requirement-ids", required=True)
    parser.add_argument("--id", dest="record_id", default=None)
    parser.add_argument(
        "--independent",
        action="store_true",
        help="Mark this observation as qualifying for the independent-observation invariant.",
    )
    parser.add_argument("--expect", choices=["pass", "fail"], default="pass")
    parser.add_argument("--supersedes", default=None)
    parser.add_argument(
        "--workspace-root",
        default=None,
        help=f"Path to tally workspace root (default: ./{DEFAULT_WORKSPACE_ROOT}/<slug>).",
    )
    parser.add_argument("--cwd", default=None)
    parser.add_argument("--notes", default=None)
    parser.add_argument(
        "--tool",
        action="append",
        default=[],
        metavar="NAME=VERSION",
        help="Record a tool version under env.tool_versions. Repeatable.",
    )
    parser.add_argument(
        "--capture-env",
        action="append",
        default=[],
        metavar="NAME",
        help="Capture the named environment variable under env.relevant_env_vars. Repeatable.",
    )
    parser.add_argument(
        "command",
        nargs=argparse.REMAINDER,
        help="Command to run after --.",
    )

    args = parser.parse_args()

    command = args.command
    if command and command[0] == "--":
        command = command[1:]
    if not command:
        sys.stderr.write("tally-record: missing command after --\n")
        return 2

    requirement_ids = parse_requirement_ids(args.requirement_ids)
    record_id = args.record_id or default_record_id(command)
    if not re.fullmatch(r"[A-Za-z0-9._-]+", record_id):
        sys.stderr.write(
            f"tally-record: record id '{record_id}' must be [A-Za-z0-9._-]+\n"
        )
        return 2

    workspace_root = (
        pathlib.Path(args.workspace_root).resolve()
        if args.workspace_root
        else (pathlib.Path.cwd() / DEFAULT_WORKSPACE_ROOT / args.slug).resolve()
    )
    if not workspace_root.exists():
        sys.stderr.write(
            f"tally-record: workspace not found at {workspace_root}. "
            "Run Step 1 closing action first, or pass --workspace-root.\n"
        )
        return 2

    observations_dir = workspace_root / "observations"
    record_path = observations_dir / f"{record_id}.md"
    if record_path.exists():
        sys.stderr.write(
            f"tally-record: record {record_path} already exists (observations are append-only). "
            "Pick a new --id.\n"
        )
        return 2

    run_cwd = pathlib.Path(args.cwd).resolve() if args.cwd else pathlib.Path.cwd()

    try:
        proc = subprocess.run(
            command,
            cwd=str(run_cwd),
            capture_output=True,
            text=True,
        )
        stdout = proc.stdout or ""
        stderr = proc.stderr or ""
        exit_code = proc.returncode
    except FileNotFoundError as e:
        stdout = ""
        stderr = f"tally-record: could not execute command: {e}\n"
        exit_code = -1

    outcome = determine_outcome(exit_code, args.expect)

    env_block: dict = {"os": platform.platform()}
    if args.tool:
        tool_versions: dict[str, str] = {}
        for entry in args.tool:
            if "=" not in entry:
                sys.stderr.write(
                    f"tally-record: --tool expects NAME=VERSION, got '{entry}'\n"
                )
                return 2
            name, version = entry.split("=", 1)
            tool_versions[name.strip()] = version.strip()
        if tool_versions:
            env_block["tool_versions"] = tool_versions
    if args.capture_env:
        captured: dict[str, str] = {}
        for var_name in args.capture_env:
            if var_name in os.environ:
                captured[var_name] = os.environ[var_name]
        if captured:
            env_block["relevant_env_vars"] = captured

    frontmatter: dict = {
        "id": record_id,
        "requirement_ids": requirement_ids,
        "command": format_command(command),
        "cwd": str(run_cwd),
        "env": env_block,
        "timestamp": iso_timestamp(),
        "outcome": outcome,
        "exit_code": exit_code,
        "produced_by": "tally-record",
    }
    if args.independent:
        frontmatter["independent"] = True
    if args.supersedes:
        frontmatter["supersedes"] = args.supersedes
    if args.notes:
        frontmatter["notes"] = args.notes

    try:
        write_record(record_path, frontmatter, stdout, stderr)
    except OSError as e:
        sys.stderr.write(f"tally-record: failed to write {record_path}: {e}\n")
        return 2

    print(str(record_path))
    return 0


if __name__ == "__main__":
    sys.exit(main())
