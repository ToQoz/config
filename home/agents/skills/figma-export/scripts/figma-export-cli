#!/usr/bin/env python3

from __future__ import annotations

import argparse
import getpass
import json
import os
import pathlib
import shlex
import subprocess
import sys
import urllib.error
import urllib.parse
import urllib.request


KEYCHAIN_SERVICE = "figma-export-skill"
FIGMA_TOKEN_URL = "https://www.figma.com/developers/api#access-tokens"
FIGMA_MINIMUM_SCOPE = "file_content:read"
FIGMA_API_BASE = "https://api.figma.com/v1"
VALID_FORMATS = {"png", "jpg", "svg", "pdf"}


class CliError(Exception):
    pass


def eprint(message: str) -> None:
    print(message, file=sys.stderr)


def run_security(args: list[str]) -> subprocess.CompletedProcess[str]:
    try:
        return subprocess.run(
            ["security", *args],
            text=True,
            capture_output=True,
            check=False,
        )
    except FileNotFoundError as exc:
        raise CliError("`security` command is not available on this system.") from exc


def project_scope_path(cwd: str | None = None) -> str:
    start = os.path.realpath(cwd or os.getcwd())
    try:
        root = subprocess.check_output(
            ["git", "-C", start, "rev-parse", "--show-toplevel"],
            text=True,
            stderr=subprocess.DEVNULL,
        ).strip()
        if root:
            return os.path.realpath(root)
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass
    return start


def skill_script_path() -> pathlib.Path:
    return pathlib.Path(__file__).resolve()


def auth_command_hint(scope_path: str) -> str:
    return (
        f"cd {shlex.quote(scope_path)} && "
        f"{shlex.quote(str(skill_script_path()))} auth"
    )


def keychain_account(scope_path: str) -> str:
    return scope_path


def keychain_read(scope_path: str) -> str | None:
    result = run_security(
        [
            "find-generic-password",
            "-s",
            KEYCHAIN_SERVICE,
            "-a",
            keychain_account(scope_path),
            "-w",
        ]
    )
    if result.returncode == 0:
        token = result.stdout.strip()
        return token or None
    stderr = result.stderr.strip()
    if result.returncode == 44 or "could not be found" in stderr.lower():
        return None
    raise CliError(f"Failed to read token from macOS Keychain: {stderr or result.returncode}")


def keychain_write(scope_path: str, token: str) -> None:
    result = run_security(
        [
            "add-generic-password",
            "-U",
            "-s",
            KEYCHAIN_SERVICE,
            "-a",
            keychain_account(scope_path),
            "-l",
            f"figma-export:{scope_path}",
            "-w",
            token,
        ]
    )
    if result.returncode != 0:
        stderr = result.stderr.strip()
        raise CliError(f"Failed to save token to macOS Keychain: {stderr or result.returncode}")


def keychain_delete(scope_path: str) -> bool:
    result = run_security(
        [
            "delete-generic-password",
            "-s",
            KEYCHAIN_SERVICE,
            "-a",
            keychain_account(scope_path),
        ]
    )
    if result.returncode == 0:
        return True
    stderr = result.stderr.strip()
    if result.returncode == 44 or "could not be found" in stderr.lower():
        return False
    raise CliError(f"Failed to delete token from macOS Keychain: {stderr or result.returncode}")


def is_tty_stdin() -> bool:
    return sys.stdin.isatty()


def normalize_node_id(node_id: str) -> str:
    value = node_id.strip()
    if not value:
        raise CliError("Node id is empty.")
    return value.replace("-", ":")


def parse_node_reference(node_value: str, file_key: str | None) -> tuple[str, str]:
    parsed = urllib.parse.urlparse(node_value)
    if parsed.scheme and parsed.netloc:
        query = urllib.parse.parse_qs(parsed.query)
        raw_node_id = query.get("node-id", [None])[0]
        if not raw_node_id:
            raise CliError("Figma URL is missing node-id.")
        path_parts = [part for part in parsed.path.split("/") if part]
        if len(path_parts) < 2:
            raise CliError("Could not parse file key from Figma URL.")
        if path_parts[0] not in {"design", "file", "proto"}:
            raise CliError(f"Unsupported Figma URL path: {parsed.path}")
        resolved_file_key = path_parts[1]
        if "branch" in path_parts:
            branch_index = path_parts.index("branch")
            if branch_index + 1 >= len(path_parts):
                raise CliError("Could not parse branch key from Figma URL.")
            resolved_file_key = path_parts[branch_index + 1]
        return resolved_file_key, normalize_node_id(raw_node_id)

    if not file_key:
        raise CliError("`--file-key` is required when `--node` is not a full Figma URL.")
    return file_key, normalize_node_id(node_value)


def figma_request_json(path: str, token: str, query: dict[str, str]) -> dict:
    url = f"{FIGMA_API_BASE}{path}?{urllib.parse.urlencode(query)}"
    request = urllib.request.Request(
        url,
        headers={
            "X-Figma-Token": token,
            "Accept": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(request) as response:
            payload = response.read()
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace").strip()
        detail = body or exc.reason
        raise CliError(f"Figma API request failed ({exc.code}): {detail}") from exc
    except urllib.error.URLError as exc:
        raise CliError(f"Network error while calling Figma API: {exc.reason}") from exc

    try:
        return json.loads(payload)
    except json.JSONDecodeError as exc:
        raise CliError("Figma API returned invalid JSON.") from exc


def download_binary(url: str, destination: pathlib.Path) -> None:
    request = urllib.request.Request(url, headers={"Accept": "*/*"})
    try:
        with urllib.request.urlopen(request) as response:
            data = response.read()
    except urllib.error.HTTPError as exc:
        raise CliError(f"Download failed ({exc.code}): {exc.reason}") from exc
    except urllib.error.URLError as exc:
        raise CliError(f"Download failed: {exc.reason}") from exc

    destination.parent.mkdir(parents=True, exist_ok=True)
    destination.write_bytes(data)


def ensure_token(scope_path: str, provided_token: str | None) -> str:
    if provided_token:
        keychain_write(scope_path, provided_token.strip())
        return provided_token.strip()

    token = keychain_read(scope_path)
    if token:
        return token

    raise CliError(
        "No Figma token configured for this project.\n"
        "Run the following in the project root in a TTY:\n"
        f"  {auth_command_hint(scope_path)}\n"
        "If you need to create a new Figma Personal Access Token for this skill, grant only:\n"
        f"  {FIGMA_MINIMUM_SCOPE}\n"
        f"Token creation page: {FIGMA_TOKEN_URL}"
    )


def export_command(args: argparse.Namespace) -> int:
    if args.format not in VALID_FORMATS:
        raise CliError(f"Unsupported format: {args.format}")
    if args.scale <= 0 or args.scale > 4:
        raise CliError("`--scale` must be between 0.01 and 4.")

    scope_path = project_scope_path(args.cwd)
    token = ensure_token(scope_path, args.token)
    file_key, node_id = parse_node_reference(args.node, args.file_key)

    response = figma_request_json(
        f"/images/{file_key}",
        token,
        {
            "ids": node_id,
            "format": args.format,
            "scale": str(args.scale),
        },
    )

    if "err" in response and response["err"]:
        raise CliError(f"Figma API error: {response['err']}")

    images = response.get("images")
    if not isinstance(images, dict):
        raise CliError(f"Unexpected API response: {json.dumps(response, ensure_ascii=True)}")

    download_url = images.get(node_id)
    if not download_url:
        raise CliError(
            "Figma did not return a render URL for this node. The node may be invalid or non-renderable."
        )

    output_path = pathlib.Path(
        args.output or f"figma-export-{node_id.replace(':', '-')}.{args.format}"
    )
    download_binary(download_url, output_path)

    result = {
        "file_key": file_key,
        "node_id": node_id,
        "format": args.format,
        "scale": args.scale,
        "output": str(output_path.resolve()),
        "project_scope": scope_path,
    }
    print(json.dumps(result, ensure_ascii=True))
    return 0


def auth_set_command(args: argparse.Namespace) -> int:
    scope_path = project_scope_path(args.cwd)
    token = (args.token or "").strip()
    if not token:
        if not is_tty_stdin():
            raise CliError(
                "No token provided. Re-run this command in a TTY from the project root, or pass `--token`."
            )
        eprint(f"Create a personal access token at: {FIGMA_TOKEN_URL}")
        eprint(f"For this skill, grant only: {FIGMA_MINIMUM_SCOPE}")
        token = getpass.getpass("Paste Figma access token: ").strip()
    if not token:
        raise CliError("No token entered.")
    keychain_write(scope_path, token)
    print(json.dumps({"status": "ok", "project_scope": scope_path}, ensure_ascii=True))
    return 0


def auth_command(args: argparse.Namespace) -> int:
    return auth_set_command(args)


def auth_status_command(args: argparse.Namespace) -> int:
    scope_path = project_scope_path(args.cwd)
    token_exists = keychain_read(scope_path) is not None
    print(
        json.dumps(
            {
                "project_scope": scope_path,
                "has_token": token_exists,
                "service": KEYCHAIN_SERVICE,
            },
            ensure_ascii=True,
        )
    )
    return 0


def auth_clear_command(args: argparse.Namespace) -> int:
    scope_path = project_scope_path(args.cwd)
    removed = keychain_delete(scope_path)
    print(
        json.dumps(
            {
                "project_scope": scope_path,
                "removed": removed,
                "service": KEYCHAIN_SERVICE,
            },
            ensure_ascii=True,
        )
    )
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="figma-export-cli",
        description="Export Figma nodes with a project-scoped token stored in macOS Keychain.",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    export_parser = subparsers.add_parser("export", help="Export a node via GET /v1/images/:key.")
    export_parser.add_argument("--node", required=True, help="Figma node id or full Figma URL.")
    export_parser.add_argument("--file-key", help="Figma file key when --node is not a URL.")
    export_parser.add_argument("--format", required=True, choices=sorted(VALID_FORMATS))
    export_parser.add_argument("--scale", required=True, type=float)
    export_parser.add_argument("--output", help="Destination file path.")
    export_parser.add_argument("--token", help="Token to save for this project before export.")
    export_parser.add_argument("--cwd", help="Project directory for token scoping.")
    export_parser.set_defaults(func=export_command)

    auth_parser = subparsers.add_parser("auth", help="Set a project-scoped Figma token, or manage it.")
    auth_parser.add_argument("--token", help="Token value to store.")
    auth_parser.add_argument("--cwd", help="Project directory for token scoping.")
    auth_parser.set_defaults(func=auth_command)

    auth_subparsers = auth_parser.add_subparsers(dest="auth_command", required=False)

    auth_status_parser = auth_subparsers.add_parser("status", help="Check whether a token exists.")
    auth_status_parser.add_argument("--cwd", help="Project directory for token scoping.")
    auth_status_parser.set_defaults(func=auth_status_command)

    auth_clear_parser = auth_subparsers.add_parser("clear", help="Delete the stored token.")
    auth_clear_parser.add_argument("--cwd", help="Project directory for token scoping.")
    auth_clear_parser.set_defaults(func=auth_clear_command)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    try:
        return args.func(args)
    except CliError as exc:
        eprint(f"Error: {exc}")
        return 1


if __name__ == "__main__":
    sys.exit(main())
