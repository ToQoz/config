emulate -L zsh

# USAGE: enter-workspace [QUERY]
#
# Pick a ghq repository via fzf and attach (outside tmux) or switch-client
# (inside tmux) to a tmux session named "owner/repo" rooted at the repo
# path. Typing a query that matches no repo and pressing Enter creates an
# ad-hoc session by that name (no working directory override).
#
# When invoked as a zle widget (bound via `zle -N`), refresh the prompt at
# the end. As a regular command (e.g., from the tmux wrapper), produce no
# stdout so callers don't see stray noise.

local root listing selection lines query pick repo target rc
local -a new_args

root=$(ghq root)
listing=$(ghq list -p | sed "s|^$root/github.com/|github:|; s|^$root/||")

selection=$(print -r -- "$listing" | fzf \
  --print-query --no-sort --exact \
  --prompt='repo> ' --query="${1:-}")
rc=$?
# 0 = selected, 1 = no match on enter. Anything else (ESC, C-c) aborts.
(( rc != 0 && rc != 1 )) && return 0

lines=("${(f)selection}")
query=${lines[1]}
pick=${lines[2]}

if [[ -n "$pick" ]]; then
  pick=${pick/#github:/$root/github.com/}
  [[ "$pick" != /* ]] && pick="$root/$pick"
  repo=$pick
  target="${repo:h:t}/${repo:t}"
  new_args=(-c "$repo")
elif [[ -n "$query" ]]; then
  target=$query
else
  return 0
fi

if [[ -z "$TMUX" ]]; then
  command tmux new-session -A -s "$target" "${new_args[@]}"
else
  command tmux has-session -t "=$target" 2>/dev/null \
    || command tmux new-session -d -s "$target" "${new_args[@]}"
  command tmux switch-client -t "=$target"
fi

[[ -n "$WIDGET" ]] && zle reset-prompt
return 0
