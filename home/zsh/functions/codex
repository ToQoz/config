emulate -L zsh

# USAGE: codex [--no-sandbox] [<codex args>...]
#
# Wrapper around the real codex CLI.
#
#   --no-sandbox  Bypass the sence sandbox and run the codex binary
#                 directly. Consumed by this wrapper; not forwarded.
#
# Sandbox behavior (default when --no-sandbox is absent):
#   - Interactive:      sence --profile code:codex --interactive -- codex --full-auto
#   - Non-interactive:  sence --profile code:codex -- codex --full-auto
#                       (used for `exec` and `review`)
#
# Remaining args are forwarded verbatim to codex.

local no_sandbox=false
if [[ "$1" == "--no-sandbox" ]]; then
  no_sandbox=true
  shift
fi

local -a cmd
if $no_sandbox; then
  cmd=(command codex --full-auto)
elif [[ "$1" == "exec" || "$1" == "e" || "$1" == "review" ]]; then
  cmd=(sence --profile code:codex -- codex --full-auto)
else
  cmd=(sence --profile code:codex --interactive -- codex --full-auto)
fi

"${cmd[@]}" "$@"
