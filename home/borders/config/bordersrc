#!/usr/bin/env bash
# Invoked by `borders` (no args) on launch. Re-invoking this script while
# borders is already running re-applies these options to the live instance,
# which is how we work around the AeroSpace accordion focus-sync bug:
# on-focus-changed in aerospace.toml runs this script to force borders to
# re-evaluate the currently focused window.
options=(
  style=round
  width=5.0
  hidpi=on
  # Active pops with a mauve accent; inactive stays near-transparent so the
  # focused window reads as the clear hero without UI noise on the rest.
  active_color=0xffcba6f7
  inactive_color=0x22606070
)
borders "${options[@]}"
