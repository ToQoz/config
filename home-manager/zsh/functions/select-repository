emulate -L zsh

local root d
root=$(ghq root)
d=$(ghq list -p | sed "s|^$root/github.com/|github:|; s|^$root/||" | fzf --no-sort --exact)
if [ $? = 0 -a -n "$d" ]; then
  d=${d/#github:/$root/github.com/}
  # If still relative (non-github host), prepend root
  [[ "$d" != /* ]] && d="$root/$d"
  cd "$d"
  zle reset-prompt
fi
