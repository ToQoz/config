#!/usr/bin/env bash

# Queue a branch rename for the current git-wt-now worktree.
#
# USAGE
#   git-wt-now-rename <new-branch-name>
#
# Writes the requested name to the worktree's state file. The git-wt-now
# zsh function reads it after the claude session exits and renames the
# branch + moves the worktree directory.
#
# EXIT CODES
#   0   queued successfully
#   2   environment error (not inside a git-wt-now worktree)
#   64  invalid arguments

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: git-wt-now-rename <new-branch-name>

Queue a branch rename for the current git-wt-now worktree. The rename is
applied after the claude session exits.

The branch name must follow the <type>/<kebab-slug> convention, where
<type> is one of: feat, fix, docs, chore, refactor, test, perf, style,
ci, revert, build.

Exit codes:
  0   queued successfully
  2   environment error (not inside a git-wt-now worktree)
  64  invalid arguments
EOF
}

if [ $# -ne 1 ]; then
  echo "error: exactly one argument required" >&2
  usage >&2
  exit 64
fi

case "$1" in
  -h|--help) usage; exit 0 ;;
esac

new_branch="$1"

if ! [[ "$new_branch" =~ ^(feat|fix|docs|chore|refactor|test|perf|style|ci|revert|build)/[a-z0-9]+(-[a-z0-9]+)*$ ]]; then
  echo "error: branch name must match <type>/<kebab-slug>, got: $new_branch" >&2
  echo "       valid types: feat, fix, docs, chore, refactor, test, perf, style, ci, revert, build" >&2
  exit 64
fi

worktree_root=$(git rev-parse --show-toplevel 2>/dev/null) \
  || { echo "error: not inside a git working tree" >&2; exit 2; }

state_file="$worktree_root/.agents/state/git-wt-now/session.json"

if [ ! -f "$state_file" ]; then
  echo "error: not inside a git-wt-now worktree (no $state_file)" >&2
  exit 2
fi

placeholder=$(jq -r '.placeholder_branch' "$state_file" 2>/dev/null) \
  || { echo "error: state file is not valid JSON: $state_file" >&2; exit 2; }

tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT
jq --arg b "$new_branch" '.desired_branch = $b' "$state_file" > "$tmp"
mv "$tmp" "$state_file"

echo "queued rename: $placeholder → $new_branch"
echo "(applied automatically when this claude session exits)"
exit 0
